{
  "version": "2.0.0",
  "inputs": [
    {
      "id": "deviceName",
      "type": "promptString",
      "description": "Device name used under pki/devices",
      "default": "device.local"
    },
    {
      "id": "ipAddress",
      "type": "promptString",
      "description": "IP address to include in the certificate SAN",
      "default": "192.168.1.10"
    },
    {
      "id": "storeLocation",
      "type": "pickString",
      "description": "Trusted root store location for the CA import",
      "options": [
        "CurrentUser",
        "LocalMachine"
      ],
      "default": "CurrentUser"
    },
    {
      "id": "caThumbprint",
      "type": "promptString",
      "description": "Thumbprint of the CA certificate to remove from the trusted root store"
    }
  ],
  "tasks": [
    {
      "label": "OpenSSL: Clone + Build 4.0.0",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        ".\\.vscode\\run-openssl-build.ps1"
      ],
      "options": { "cwd": "${workspaceFolder}" },
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": []
    },
    {
      "label": "OpenSSL: Detect NASM",
      "type": "shell",
      "command": "where nasm || echo ERROR: NASM not found in PATH",
      "problemMatcher": []
    },
    {
      "label": "OpenSSL: Configure",
      "type": "shell",
      "command": "perl Configure VC-WIN64A",
      "options": { "cwd": "${workspaceFolder}" },
      "dependsOn": "OpenSSL: Detect NASM",
      "problemMatcher": []
    },
    {
      "label": "OpenSSL: Build",
      "type": "shell",
      "command": "nmake",
      "options": { "cwd": "${workspaceFolder}" },
      "dependsOn": "OpenSSL: Configure",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "OpenSSL: Test",
      "type": "shell",
      "command": "nmake test",
      "options": { "cwd": "${workspaceFolder}" },
      "dependsOn": "OpenSSL: Build",
      "problemMatcher": []
    },
    {
      "label": "OpenSSL: Install",
      "type": "shell",
      "command": "nmake install",
      "options": { "cwd": "${workspaceFolder}" },
      "dependsOn": "OpenSSL: Test",
      "problemMatcher": []
    },
    {
      "label": "OpenSSL: Clean",
      "type": "shell",
      "command": "nmake clean",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "OpenSSL: Add to PATH (CurrentUser)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        ".\\install-openssl.ps1",
        "-Scope",
        "CurrentUser"
      ],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "OpenSSL: Remove from PATH (CurrentUser)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        ".\\install-openssl.ps1",
        "-Scope",
        "CurrentUser",
        "-Uninstall"
      ],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "PKI: Bootstrap Folder Structure",
      "type": "shell",
      "command": "powershell -ExecutionPolicy Bypass -File ./pki-bootstrap.ps1",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "PKI: Create Root CA",
      "type": "shell",
      "command": "powershell -ExecutionPolicy Bypass -File ./create-ca.ps1",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "PKI: Issue Device Certificate",
      "type": "shell",
      "command": "powershell -ExecutionPolicy Bypass -File ./issue-cert.ps1 -DeviceName ${input:deviceName} -IPAddress ${input:ipAddress}",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "PKI: Export Device Certificate as PFX",
      "type": "shell",
      "command": "openssl pkcs12 -export -out ./pki/devices/${input:deviceName}/device.pfx -inkey ./pki/devices/${input:deviceName}/device.key -in ./pki/devices/${input:deviceName}/device.crt -certfile ./pki/ca/myCA.pem",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "PKI: Inspect Device Certificate",
      "type": "shell",
      "command": "openssl x509 -in ./pki/devices/${input:deviceName}/device.crt -text -noout",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "PKI: Install Root CA into Trusted Root Store",
      "type": "shell",
      "command": "powershell -ExecutionPolicy Bypass -File ./install-ca-cert.ps1 -StoreLocation ${input:storeLocation}",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "PKI: Remove Root CA from Trusted Root Store",
      "type": "shell",
      "command": "powershell -ExecutionPolicy Bypass -File ./remove-ca-cert.ps1 -Thumbprint ${input:caThumbprint} -StoreLocation ${input:storeLocation}",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "Deploy: Raspberry Pi",
      "type": "shell",
      "command": "powershell -ExecutionPolicy Bypass -File .vscode/deploy-pi.ps1 -DeviceName raspberrypi.local -PiHost 192.168.1.50",
      "problemMatcher": []
    },
    {
      "label": "Deploy: OC200",
      "type": "shell",
      "command": "powershell -ExecutionPolicy Bypass -File .vscode/deploy-oc200.ps1 -DeviceName omada.local -ControllerURL https://192.168.1.80",
      "problemMatcher": []
    }
  ]
}
